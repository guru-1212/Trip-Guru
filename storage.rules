rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isFitTrackPartner(ownerUid) {
      return firestore.exists(/databases/(default)/documents/fittrackPartners/$(ownerUid + '_' + request.auth.uid))
        && firestore.get(/databases/(default)/documents/fittrackPartners/$(ownerUid + '_' + request.auth.uid)).data.inviteStatus == 'accepted';
    }

    function isYogaPartner(ownerUid) {
      return firestore.exists(/databases/(default)/documents/yogaPartners/$(ownerUid + '_' + request.auth.uid))
        && firestore.get(/databases/(default)/documents/yogaPartners/$(ownerUid + '_' + request.auth.uid)).data.inviteStatus == 'accepted';
    }

    match /users/{userId}/{allPaths=**} {
      allow read: if isAuth();
      allow write: if isOwner(userId) || isFitTrackPartner(userId) || isYogaPartner(userId);
    }

    match /trips/{tripId}/receipts/{fileName} {
      allow read: if isAuth();
      allow write: if isAuth()
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /rooms/{roomId}/receipts/{fileName} {
      allow read: if isAuth();
      allow write: if isAuth()
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /trips/{tripId}/memories/{fileName} {
      allow read: if isAuth();
      allow write: if isAuth()
        && request.resource.size < 50 * 1024 * 1024;
    }

    match /trips/{tripId}/plan/{fileName} {
      allow read: if isAuth();
      allow write: if isAuth()
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
